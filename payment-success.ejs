<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <%- metaPixelSnippet %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Lora:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300;1,9..40,400&display=swap" rel="stylesheet">
  <style>
    :root {
      --warm-cream: #FAF7F2;
      --deep-sage: #3D5A47;
      --light-sage: #7A9E87;
      --soft-terracotta: #C4856A;
      --dark-text: #1A1A1A;
      --muted-text: #6B6B6B;
      --pale-sage: #E8F0EA;
      --warm-blush: #F2E6DF;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--warm-cream);
      color: var(--dark-text);
      line-height: 1.7;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }
    a { color: inherit; text-decoration: none; }

    nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 24px 48px;
      max-width: 1200px;
      margin: 0 auto;
      width: 100%;
    }
    .logo {
      font-family: 'Lora', serif;
      font-weight: 800;
      font-size: 24px;
      color: var(--deep-sage);
      letter-spacing: -0.5px;
    }

    .success-container {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 40px 24px 80px;
    }

    .success-card {
      background: white;
      border-radius: 24px;
      padding: 56px 48px;
      max-width: 520px;
      width: 100%;
      text-align: center;
      border: 1px solid rgba(61, 90, 71, 0.1);
      box-shadow: 0 8px 48px rgba(61, 90, 71, 0.08);
    }

    .success-icon {
      width: 72px;
      height: 72px;
      background: var(--pale-sage);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 28px;
      font-size: 32px;
    }

    .success-eyebrow {
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: var(--soft-terracotta);
      margin-bottom: 12px;
    }

    .success-card h1 {
      font-family: 'Lora', serif;
      font-weight: 800;
      font-size: 30px;
      color: var(--deep-sage);
      letter-spacing: -0.8px;
      margin-bottom: 16px;
      line-height: 1.15;
    }

    .success-card p {
      font-size: 16px;
      color: var(--muted-text);
      margin-bottom: 12px;
    }

    .email-note {
      font-size: 14px;
      color: var(--muted-text);
      background: var(--pale-sage);
      border-radius: 10px;
      padding: 12px 16px;
      margin: 20px 0 32px;
    }
    .email-note strong { color: var(--deep-sage); }

    .tier-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: var(--warm-blush);
      color: var(--soft-terracotta);
      font-size: 13px;
      font-weight: 600;
      padding: 6px 14px;
      border-radius: 100px;
      margin-bottom: 32px;
    }

    .cta-btn {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: var(--deep-sage);
      color: white;
      font-family: 'DM Sans', sans-serif;
      font-weight: 500;
      font-size: 16px;
      padding: 16px 36px;
      border-radius: 100px;
      transition: background 0.2s ease, transform 0.15s ease;
    }
    .cta-btn:hover { background: #2d4535; transform: translateY(-2px); }

    footer {
      border-top: 1px solid rgba(61, 90, 71, 0.1);
      padding: 24px 48px;
      max-width: 1200px;
      margin: 0 auto;
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .footer-logo {
      font-family: 'Lora', serif;
      font-weight: 800;
      font-size: 18px;
      color: var(--deep-sage);
    }
    .footer-note { font-size: 13px; color: var(--muted-text); }

    @media (max-width: 600px) {
      nav { padding: 20px; }
      .success-card { padding: 40px 28px; }
      footer { padding: 20px; }
    }
  </style>
</head>
<body>

  <nav>
    <a href="/" class="logo">Unbound</a>
  </nav>

  <div class="success-container">
    <div class="success-card">
      <div class="success-icon">🌿</div>
      <div class="success-eyebrow">Payment confirmed</div>
      <h1>You're in. Welcome.</h1>

      <% if (tier === 'premium') { %>
        <div class="tier-badge">✦ Premium access</div>
        <p>You've unlocked the full Unbound course plus community access when it launches.</p>
      <% } else { %>
        <div class="tier-badge">✦ Full course access</div>
        <p>You've unlocked the complete Unbound course — all current and future modules.</p>
      <% } %>

      <% if (email) { %>
        <div class="email-note">
          Receipt sent to <strong><%= email %></strong>.<br>
          Your access is tied to this browser session — bookmark the course page.
        </div>
      <% } else { %>
        <div class="email-note">
          Your access is saved to this browser session. Bookmark the course to return easily.
        </div>
      <% } %>

      <a href="/learn" class="cta-btn">
        Continue to the course
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M3 8h10M8 3l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>

  <footer>
    <span class="footer-logo">Unbound</span>
    <span class="footer-note">Questions? <a href="mailto:unbound@polsia.app" style="color:var(--soft-terracotta);">unbound@polsia.app</a></span>
  </footer>

</body>
</html>
