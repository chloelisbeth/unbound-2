  <script>
    (function() {
      var form = document.getElementById('ecForm');
      if (!form) return;
      form.addEventListener('submit', async function(e) {
        e.preventDefault();
        var btn = document.getElementById('ecSubmit');
        var errEl = document.getElementById('ecError');
        var email = document.getElementById('ecEmail').value.trim();
        var name = document.getElementById('ecName').value.trim();

        errEl.style.display = 'none';
        btn.disabled = true;
        document.getElementById('ecBtnLabel').textContent = 'Saving…';

        try {
          var res = await fetch('/api/subscribe', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email: email, name: name, source: 'landing' }),
          });
          var data = await res.json();
          if (!res.ok) {
            errEl.textContent = data.error || 'Something went wrong.';
            errEl.style.display = 'block';
            btn.disabled = false;
            document.getElementById('ecBtnLabel').textContent = 'Start Module 1 Free';
            return;
          }
          // Show success, then redirect
          form.style.display = 'none';
          document.getElementById('ecSuccess').style.display = 'flex';
          if (data.metaPixelLead) { eval(data.metaPixelLead); }
          setTimeout(function() { window.location.href = '/learn'; }, 1400);
        } catch(err) {
          errEl.textContent = 'Network error. Please try again.';
          errEl.style.display = 'block';
          btn.disabled = false;
          document.getElementById('ecBtnLabel').textContent = 'Start Module 1 Free';
        }
      });
    })();
  </script>

