<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="A 9-page tactical guide for breaking the codependent spiral before you act on it. $12. Instant email delivery.">
  <%- metaPixelSnippet %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400;1,600&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300;1,9..40,400&display=swap" rel="stylesheet">
  <style>
    :root {
      --cream: #FAF7F2;
      --sage: #3D5A47;
      --light-sage: #7A9E87;
      --pale-sage: #E8F0EA;
      --terracotta: #C4856A;
      --dark-terracotta: #a66650;
      --warm-blush: #F2E6DF;
      --dark: #1A1A1A;
      --muted: #6B6B6B;
      --white: #ffffff;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--cream);
      color: var(--dark);
      line-height: 1.7;
    }
    a { color: inherit; text-decoration: none; }

    /* ─── Nav ──────────────────────────────────────── */
    nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 22px 48px;
      max-width: 1200px;
      margin: 0 auto;
    }
    .logo {
      font-family: 'Lora', serif;
      font-weight: 800;
      font-size: 22px;
      color: var(--sage);
      letter-spacing: -0.5px;
    }
    .nav-label {
      font-size: 12px;
      color: var(--light-sage);
      font-weight: 500;
      letter-spacing: 2px;
      text-transform: uppercase;
    }
    .nav-cta {
      background: var(--sage);
      color: white;
      font-weight: 500;
      font-size: 13px;
      padding: 9px 20px;
      border-radius: 100px;
      transition: background 0.2s;
    }
    .nav-cta:hover { background: #2d4535; }

    /* ─── Hero ─────────────────────────────────────── */
    .hero {
      max-width: 860px;
      margin: 0 auto;
      padding: 72px 24px 0;
      text-align: center;
    }
    .hero-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: var(--terracotta);
      margin-bottom: 24px;
    }
    .eyebrow-dot {
      width: 5px;
      height: 5px;
      background: var(--terracotta);
      border-radius: 50%;
      display: inline-block;
    }
    .hero h1 {
      font-family: 'Lora', serif;
      font-weight: 800;
      font-size: clamp(38px, 6vw, 64px);
      color: var(--sage);
      line-height: 1.05;
      letter-spacing: -2px;
      margin-bottom: 28px;
    }
    .hero h1 em {
      font-style: italic;
      color: var(--terracotta);
    }
    .hero-subhead {
      font-size: clamp(17px, 2.5vw, 20px);
      color: var(--muted);
      max-width: 540px;
      margin: 0 auto 40px;
      line-height: 1.6;
    }

    /* ─── CTA cluster ──────────────────────────────── */
    .cta-cluster {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 14px;
      margin-bottom: 56px;
    }
    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: var(--terracotta);
      color: white;
      font-family: 'DM Sans', sans-serif;
      font-weight: 600;
      font-size: 17px;
      padding: 18px 40px;
      border-radius: 100px;
      transition: background 0.2s ease, transform 0.15s ease, box-shadow 0.15s ease;
      box-shadow: 0 4px 20px rgba(196, 133, 106, 0.35);
    }
    .btn-primary:hover {
      background: var(--dark-terracotta);
      transform: translateY(-2px);
      box-shadow: 0 8px 28px rgba(196, 133, 106, 0.4);
    }
    .price-note {
      font-size: 14px;
      color: var(--muted);
      letter-spacing: 0.2px;
    }
    .price-note strong { color: var(--dark); }

    /* ─── PDF preview mockup ───────────────────────── */
    .guide-preview {
      max-width: 720px;
      margin: 0 auto 80px;
      padding: 0 24px;
    }
    .guide-card {
      background: white;
      border-radius: 20px;
      border: 1px solid rgba(61, 90, 71, 0.1);
      box-shadow: 0 12px 60px rgba(61, 90, 71, 0.1);
      overflow: hidden;
      display: grid;
      grid-template-columns: 1fr 1fr;
    }
    .guide-cover {
      background: var(--sage);
      padding: 48px 40px;
      color: white;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      min-height: 340px;
    }
    .guide-cover-label {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: rgba(255,255,255,0.55);
      margin-bottom: 32px;
    }
    .guide-cover h2 {
      font-family: 'Lora', serif;
      font-weight: 800;
      font-size: 26px;
      line-height: 1.2;
      letter-spacing: -0.5px;
      margin-bottom: 12px;
    }
    .guide-cover-sub {
      font-size: 13px;
      color: rgba(255,255,255,0.7);
      line-height: 1.6;
    }
    .guide-cover-footer {
      font-size: 11px;
      color: rgba(255,255,255,0.45);
      letter-spacing: 0.5px;
    }
    .guide-contents {
      padding: 36px 32px;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    .guide-contents-label {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: var(--terracotta);
      margin-bottom: 20px;
    }
    .guide-page {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      padding: 9px 0;
      border-bottom: 1px solid rgba(61, 90, 71, 0.07);
    }
    .guide-page:last-child { border-bottom: none; }
    .page-num {
      font-size: 11px;
      font-weight: 600;
      color: var(--terracotta);
      background: var(--warm-blush);
      padding: 2px 7px;
      border-radius: 4px;
      flex-shrink: 0;
      margin-top: 2px;
    }
    .page-title {
      font-size: 13px;
      font-weight: 500;
      color: var(--dark);
      line-height: 1.4;
    }
    .page-desc {
      font-size: 11.5px;
      color: var(--muted);
      line-height: 1.4;
    }

    /* ─── Who it's for ─────────────────────────────── */
    .who-section {
      max-width: 720px;
      margin: 0 auto 80px;
      padding: 0 24px;
    }
    .section-eyebrow {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: var(--terracotta);
      margin-bottom: 16px;
    }
    .who-section h2 {
      font-family: 'Lora', serif;
      font-weight: 800;
      font-size: clamp(26px, 4vw, 36px);
      color: var(--sage);
      letter-spacing: -1px;
      margin-bottom: 32px;
      line-height: 1.2;
    }
    .who-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0;
    }
    .who-item {
      display: flex;
      align-items: flex-start;
      gap: 14px;
      padding: 18px 0;
      border-bottom: 1px solid rgba(61, 90, 71, 0.09);
    }
    .who-item:last-child { border-bottom: none; }
    .who-icon {
      width: 36px;
      height: 36px;
      border-radius: 10px;
      background: var(--warm-blush);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 16px;
      flex-shrink: 0;
      margin-top: 2px;
    }
    .who-item p {
      font-size: 15px;
      color: var(--dark);
      line-height: 1.55;
    }
    .who-item p strong { color: var(--sage); }

    /* ─── Callout quote ────────────────────────────── */
    .quote-section {
      max-width: 680px;
      margin: 0 auto 80px;
      padding: 0 24px;
    }
    .quote-card {
      background: var(--sage);
      border-radius: 20px;
      padding: 48px 48px;
      color: white;
      position: relative;
    }
    .quote-mark {
      font-family: 'Lora', serif;
      font-size: 80px;
      line-height: 1;
      color: rgba(255,255,255,0.12);
      position: absolute;
      top: 24px;
      left: 36px;
    }
    .quote-text {
      font-family: 'Lora', serif;
      font-size: clamp(18px, 3vw, 24px);
      font-style: italic;
      line-height: 1.5;
      color: white;
      margin-bottom: 24px;
      position: relative;
      z-index: 1;
    }
    .quote-attr {
      font-size: 13px;
      color: rgba(255,255,255,0.6);
      letter-spacing: 0.3px;
    }

    /* ─── What you get ─────────────────────────────── */
    .what-section {
      max-width: 720px;
      margin: 0 auto 80px;
      padding: 0 24px;
    }
    .what-section h2 {
      font-family: 'Lora', serif;
      font-weight: 800;
      font-size: clamp(26px, 4vw, 36px);
      color: var(--sage);
      letter-spacing: -1px;
      margin-bottom: 8px;
      line-height: 1.2;
    }
    .what-section > p {
      font-size: 16px;
      color: var(--muted);
      margin-bottom: 36px;
    }
    .what-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }
    .what-item {
      background: white;
      border: 1px solid rgba(61, 90, 71, 0.09);
      border-radius: 14px;
      padding: 22px 20px;
      display: flex;
      align-items: flex-start;
      gap: 14px;
    }
    .what-item-icon {
      width: 40px;
      height: 40px;
      border-radius: 12px;
      background: var(--pale-sage);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
      flex-shrink: 0;
    }
    .what-item-title {
      font-size: 14px;
      font-weight: 600;
      color: var(--sage);
      margin-bottom: 4px;
    }
    .what-item-desc {
      font-size: 12.5px;
      color: var(--muted);
      line-height: 1.55;
    }

    /* ─── Final CTA ────────────────────────────────── */
    .final-cta {
      max-width: 640px;
      margin: 0 auto 96px;
      padding: 0 24px;
      text-align: center;
    }
    .final-cta h2 {
      font-family: 'Lora', serif;
      font-weight: 800;
      font-size: clamp(28px, 4vw, 40px);
      color: var(--sage);
      letter-spacing: -1px;
      line-height: 1.15;
      margin-bottom: 18px;
    }
    .final-cta p {
      font-size: 16px;
      color: var(--muted);
      margin-bottom: 36px;
      max-width: 460px;
      margin-left: auto;
      margin-right: auto;
    }
    .trust-row {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 24px;
      margin-top: 20px;
      flex-wrap: wrap;
    }
    .trust-item {
      display: flex;
      align-items: center;
      gap: 7px;
      font-size: 13px;
      color: var(--muted);
    }
    .trust-item svg { color: var(--sage); }

    /* ─── Error banner ─────────────────────────────── */
    .error-banner {
      max-width: 600px;
      margin: 24px auto 0;
      padding: 12px 18px;
      background: #FFF0ED;
      border: 1px solid rgba(196, 133, 106, 0.4);
      border-radius: 10px;
      font-size: 14px;
      color: #8B4513;
      text-align: center;
    }

    /* ─── Footer ───────────────────────────────────── */
    footer {
      border-top: 1px solid rgba(61, 90, 71, 0.1);
      padding: 28px 48px;
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .footer-logo {
      font-family: 'Lora', serif;
      font-weight: 800;
      font-size: 18px;
      color: var(--sage);
    }
    .footer-note { font-size: 13px; color: var(--muted); }

    /* ─── Responsive ───────────────────────────────── */
    @media (max-width: 700px) {
      nav { padding: 18px 20px; }
      .nav-label { display: none; }
      .guide-card { grid-template-columns: 1fr; }
      .guide-cover { min-height: auto; }
      .what-grid { grid-template-columns: 1fr; }
      .quote-card { padding: 36px 28px; }
      footer { padding: 24px 20px; flex-direction: column; gap: 12px; text-align: center; }
    }
  </style>
</head>
<body>

  <nav>
    <a href="/" class="logo">Unbound</a>
    <span class="nav-label">From the makers of Unbound</span>
    <a href="/learn" class="nav-cta">Free course →</a>
  </nav>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-eyebrow">
      <span class="eyebrow-dot"></span>
      9-page PDF guide · $<%= price %> · Instant delivery
    </div>
    <h1>5 minutes.<br><em>One breath.</em><br>Break the loop.</h1>
    <p class="hero-subhead">
      A regulation guide for the moment <em>before</em> you react. Before the text, before the apology, before the spiral. Built for codependent patterns.
    </p>
    <div class="cta-cluster">
      <a href="/api/track/checkout?tier=reset&url=<%= encodeURIComponent(stripeUrl) %>" class="btn-primary">
        Get the 5-Minute Reset — $<%= price %>
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M3 8h10M8 3l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <span class="price-note"><strong>$<%= price %> once.</strong> PDF delivered to your email instantly.</span>
    </div>
  </section>

  <!-- What's inside preview -->
  <div class="guide-preview">
    <div class="guide-card">
      <div class="guide-cover">
        <div class="guide-cover-label">Unbound · Regulation Guide</div>
        <div>
          <h2>The 5-Minute Reset</h2>
          <p class="guide-cover-sub">An in-the-moment tool for when you're stuck in the loop and need to stop before you act.</p>
        </div>
        <div class="guide-cover-footer">9 pages · PDF</div>
      </div>
      <div class="guide-contents">
        <div class="guide-contents-label">What's inside</div>
        <div class="guide-page">
          <span class="page-num">1–2</span>
          <div>
            <div class="page-title">Why the loop happens</div>
            <div class="page-desc">Why the spiral happens, and why telling yourself to stop doesn't work</div>
          </div>
        </div>
        <div class="guide-page">
          <span class="page-num">3</span>
          <div>
            <div class="page-title">The 5-minute protocol</div>
            <div class="page-desc">A grounding sequence you can do anywhere, including a bathroom stall or your car</div>
          </div>
        </div>
        <div class="guide-page">
          <span class="page-num">4–6</span>
          <div>
            <div class="page-title">Pattern-specific resets</div>
            <div class="page-desc">Tailored sequences for: the spiral, hypervigilance, the urge to fix, the guilt rush</div>
          </div>
        </div>
        <div class="guide-page">
          <span class="page-num">7–8</span>
          <div>
            <div class="page-title">Quick-reference cards</div>
            <div class="page-desc">Screenshot these for your phone — one card per pattern</div>
          </div>
        </div>
        <div class="guide-page">
          <span class="page-num">9</span>
          <div>
            <div class="page-title">Building the habit</div>
            <div class="page-desc">Making this automatic so you reach for it before you need to think about it</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Who it's for -->
  <section class="who-section">
    <div class="section-eyebrow">Who this is for</div>
    <h2>If any of these sound familiar,<br>this is for you.</h2>
    <ul class="who-list">
      <li class="who-item">
        <div class="who-icon">📱</div>
        <p>You <strong>send the text</strong> — the over-explained one, the checking-in one, the one you immediately regret — before you've had a chance to pause.</p>
      </li>
      <li class="who-item">
        <div class="who-icon">😶</div>
        <p>You <strong>scan the room</strong> for who's upset and feel responsible for fixing it, even when it has nothing to do with you.</p>
      </li>
      <li class="who-item">
        <div class="who-icon">🔁</div>
        <p>You <strong>spiral quickly</strong> — a short silence, an unreturned message, a slightly different tone — and your nervous system treats it like a threat.</p>
      </li>
      <li class="who-item">
        <div class="who-icon">🙋</div>
        <p>You <strong>say yes</strong> when you mean no, apologize when nothing is your fault, and feel guilty for having needs at all.</p>
      </li>
      <li class="who-item">
        <div class="who-icon">💡</div>
        <p>You <strong>already know you do this.</strong> You just haven't found something that actually works in the moment, not two hours later.</p>
      </li>
    </ul>
  </section>

  <!-- Quote -->
  <div class="quote-section">
    <div class="quote-card">
      <div class="quote-mark">"</div>
      <p class="quote-text">Knowing a pattern and being able to stop it are different problems. It's not about willpower. It's about how fast the nervous system moves, and what you have ready when it does.</p>
      <p class="quote-attr">— From the 5-Minute Reset, page 2</p>
    </div>
  </div>

  <!-- What you get -->
  <section class="what-section">
    <div class="section-eyebrow">What you get</div>
    <h2>A tool, not a theory.</h2>
    <p>Built for use, not reading. Here's what you actually get.</p>
    <div class="what-grid">
      <div class="what-item">
        <div class="what-item-icon">🧠</div>
        <div>
          <div class="what-item-title">The science, briefly</div>
          <div class="what-item-desc">Why your body reacts before your brain even gets involved. Plain language, no jargon.</div>
        </div>
      </div>
      <div class="what-item">
        <div class="what-item-icon">⏱️</div>
        <div>
          <div class="what-item-title">The 5-minute protocol</div>
          <div class="what-item-desc">A grounding sequence that works in a bathroom stall, a parking lot, a moment alone.</div>
        </div>
      </div>
      <div class="what-item">
        <div class="what-item-icon">🗂️</div>
        <div>
          <div class="what-item-title">Pattern-specific resets</div>
          <div class="what-item-desc">Different loops call for different approaches. The guide covers the four most common ones.</div>
        </div>
      </div>
      <div class="what-item">
        <div class="what-item-icon">📲</div>
        <div>
          <div class="what-item-title">Screenshot-ready cards</div>
          <div class="what-item-desc">Quick-reference versions of each reset, designed for your phone's camera roll.</div>
        </div>
      </div>
      <div class="what-item">
        <div class="what-item-icon">🔄</div>
        <div>
          <div class="what-item-title">Building the habit</div>
          <div class="what-item-desc">How to make this automatic — so you reach for it before you're too deep to think.</div>
        </div>
      </div>
      <div class="what-item">
        <div class="what-item-icon">📄</div>
        <div>
          <div class="what-item-title">9 pages, no filler</div>
          <div class="what-item-desc">Practical and dense. Written like a friend who's been through it, not a corporate self-help PDF.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="final-cta">
    <h2>The next loop doesn't have to win.</h2>
    <p>$<%= price %>. One purchase. In your inbox in seconds. Keep it on your phone for the next time you feel it coming.</p>
    <a href="/api/track/checkout?tier=reset&url=<%= encodeURIComponent(stripeUrl) %>" class="btn-primary" style="margin: 0 auto; display: inline-flex;">
      Get the 5-Minute Reset — $<%= price %>
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
        <path d="M3 8h10M8 3l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
    <div class="trust-row">
      <span class="trust-item">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M8 1l1.8 3.6 4 .6-2.9 2.8.7 4L8 10l-3.6 1.9.7-4L2.2 5.2l4-.6L8 1z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/></svg>
        Secure checkout via Stripe
      </span>
      <span class="trust-item">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        PDF delivered instantly
      </span>
      <span class="trust-item">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M8 14A6 6 0 108 2a6 6 0 000 12z" stroke="currentColor" stroke-width="1.3"/><path d="M8 5v4l2.5 2.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
        No subscription, no renewal
      </span>
    </div>
  </section>

  <footer>
    <span class="footer-logo">Unbound</span>
    <span class="footer-note">
      Questions? <a href="mailto:unbound@polsia.app" style="color:var(--terracotta);">unbound@polsia.app</a>
      &nbsp;·&nbsp; <a href="/learn" style="color:var(--muted);">Free module →</a>
    </span>
  </footer>

</body>
</html>
