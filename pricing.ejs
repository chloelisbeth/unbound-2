  <% if (typeof launchActive !== 'undefined' && launchActive) { %>
  <script>
    (function () {
      var endDate = new Date('<%= launchEndDate %>');
      var el = document.getElementById('countdown-display');
      if (!el) return;

      function update() {
        var now = new Date();
        var diff = endDate - now;

        if (diff <= 0) {
          // Window closed — hide the banner gracefully
          var banner = el.closest('.launch-banner');
          if (banner) banner.style.display = 'none';
          return;
        }

        var days = Math.floor(diff / (1000 * 60 * 60 * 24));
        var hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        var mins = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
        var secs = Math.floor((diff % (1000 * 60)) / 1000);

        var parts = [];
        if (days > 0) parts.push(days + 'd');
        parts.push(pad(hours) + 'h');
        parts.push(pad(mins) + 'm');
        parts.push(pad(secs) + 's');
        el.textContent = parts.join(' ');
      }

      function pad(n) { return n < 10 ? '0' + n : '' + n; }

      update();
      setInterval(update, 1000);
    })();
  </script>
  <% } %>

